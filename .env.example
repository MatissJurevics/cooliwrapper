PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=https://uigendeploy.mati.ss

# Coolify defaults to https://coolify.mati.ss/api/v1 when unset.
COOLIFY_BASE_URL=https://coolify.mati.ss
COOLIFY_TOKEN=

# Optional token for this wrapper API. Send it as x-api-key or Bearer token.
WRAPPER_API_KEY=

# Optional defaults used by ZIP manifests so callers do not repeat these values.
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT_NAME=production
COOLIFY_ENVIRONMENT_UUID=
COOLIFY_DESTINATION_UUID=

MAX_ZIP_BYTES=104857600
MAX_EXTRACTED_BYTES=524288000
MAX_EXTRACTED_FILES=5000
KEEP_UPLOADS=false

# Static HTML ZIP behavior.
STATIC_SITE_STORAGE_ROOT=uploads/static-sites
STATIC_SITE_ARTIFACT_STORAGE_ROOT=uploads/artifacts
STATIC_SITE_DOMAIN_SUFFIX=deploymentsv1.atrium.dubsof.com
STATIC_SITE_DOMAIN_SCHEME=https
MAX_STATIC_ARCHIVE_BYTES=26214400
